# DocFlow AI — environment variables
# Copy this file to ".env" and fill in your real values. NEVER commit ".env".

# Required: your Anthropic API key (server-side only, never exposed to the browser).
ANTHROPIC_API_KEY=

# Optional: comma-separated allow-list of origins permitted to call the API.
# Leave empty to allow all origins (convenient for local development).
# Example: CORS_ORIGIN=https://your-app.vercel.app,http://localhost:5173
CORS_ORIGIN=

# Optional: local Express server port (defaults to 3001).
PORT=3001
